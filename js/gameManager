import * as THREE from 'three';
import { Player } from './player.js';
import { Enemy } from './enemy.js';
import { UIManager } from './ui.js';

export class GameManager {
    constructor(container) {
        this.container = container;
        this.ui = new UIManager();
        
        this.state = 'MENU'; // MENU, PLAYING, PAUSED, GAMEOVER
        this.score = 0;
        this.clock = new THREE.Clock();
        
        this.input = {
            keys: {},
            mousePos: null,
            isMouseDown: false
        };

        this.initThree();
        this.initLevel();
        
        // Game Entities
        this.player = null;
        this.enemies = [];
        this.projectiles = [];
        
        // Spawning
        this.spawnTimer = 0;
        this.spawnRate = 2.0;

        // Bind loops
        this.animate = this.animate.bind(this);
    }

    initThree() {
        this.scene = new THREE.Scene();
        this.scene.fog = new THREE.FogExp2(0x050510, 0.02);

        this.camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);
        // Angled top-down view
        this.camera.position.set(0, 18, 12);
        this.camera.lookAt(0, 0, 0);

        this.renderer = new THREE.WebGLRenderer({ antialias: true });
        this.renderer.setSize(window.innerWidth, window.innerHeight);
        this.renderer.shadowMap.enabled = true;
        this.container.appendChild(this.renderer.domElement);

        // Lighting
        const ambient = new THREE.AmbientLight(0xffffff, 0.3);
        this.scene.add(ambient);

        const dirLight = new THREE.DirectionalLight(0xffffff, 1);
        dirLight.position.set(10, 20, 10);
        dirLight.castShadow = true;
        dirLight.shadow.camera.left = -25;
        dirLight.shadow.camera.right = 25;
        dirLight.shadow.camera.top = 25;
        dirLight.shadow.camera.bottom = -25;
        this.scene.add(dirLight);

        // Raycaster plane for mouse aiming
        this.raycaster = new THREE.Raycaster();
        this.mousePlane = new THREE.Plane(new THREE.Vector3(0, 1, 0), 0);
    }

    initLevel() {
        // Floor
        const floorGeo = new THREE.PlaneGeometry(40, 40);
        const floorMat = new THREE.MeshStandardMaterial({ color: 0x111122 });
        const floor = new THREE.Mesh(floorGeo, floorMat);
        floor.rotation.x = -Math.PI / 2;
        floor.receiveShadow = true;
        this.scene.add(floor);

        // Grid helper for arcade feel
        const gridHelper = new THREE.GridHelper(40, 40, 0x00ffff, 0x004444);
        gridHelper.position.y = 0.01;
        this.scene.add(gridHelper);

        // Walls
        const wallMat = new THREE.MeshStandardMaterial({ color: 0x0088ff, transparent: true, opacity: 0.5 });
        const wallGeo = new THREE.BoxGeometry(40, 2, 1);
        
        const wallN = new THREE.Mesh(wallGeo, wallMat);
        wallN.position.set(0, 1, -20.5);
        this.scene.add(wallN);
        
        const wallS = new THREE.Mesh(wallGeo, wallMat);
        wallS.position.set(0, 1, 20.5);
        this.scene.add(wallS);
        
        const wallGeoV = new THREE.BoxGeometry(1, 2, 40);
        const wallE = new THREE.Mesh(wallGeoV, wallMat);
        wallE.position.set(20.5, 1, 0);
        this.scene.add(wallE);
        
        const wallW = new THREE.Mesh(wallGeoV, wallMat);
        wallW.position.set(-20.5, 1, 0);
        this.scene.add(wallW);
    }

    startGame() {
        // Reset state
        this.score = 0;
        this.ui.updateScore(this.score);
        this.spawnRate = 2.0;
        
        // Clear old entities
        if (this.player) this.scene.remove(this.player.mesh);
        this.enemies.forEach(e => this.scene.remove(e.mesh));
        this.projectiles.forEach(p => this.scene.remove(p.mesh));
        this.enemies = [];
        this.projectiles = [];

        this.player = new Player(this.scene, this);
        this.ui.updateHealth(this.player.health, this.player.maxHealth);
        this.ui.updateDash(true);

        this.state = 'PLAYING';
        this.ui.showScreen('hud');
        this.clock.start();
    }

    spawnProjectile(pos, dir, isPlayer) {
        const geo = new THREE.SphereGeometry(0.2, 8, 8);
        const mat = new THREE.MeshBasicMaterial({ color: isPlayer ? 0xffff00 : 0xff0000 });
        const mesh = new THREE.Mesh(geo, mat);
        mesh.position.copy(pos);
        this.scene.add(mesh);

        this.projectiles.push({
            mesh: mesh,
            dir: dir,
            speed: 25,
            isPlayer: isPlayer,
            life: 2.0, // seconds
            active: true
        });
    }

    updateProjectiles(dt) {
        for (let i = this.projectiles.length - 1; i >= 0; i--) {
            const p = this.projectiles[i];
            if (!p.active) continue;

            p.life -= dt;
            if (p.life <= 0) {
                this.scene.remove(p.mesh);
                this.projectiles.splice(i, 1);
                continue;
            }

            p.mesh.position.addScaledVector(p.dir, p.speed * dt);

            // Simple collision check (Sphere vs Box approximation)
            if (p.isPlayer) {
                for (let e of this.enemies) {
                    if (e.active && p.mesh.position.distanceTo(e.mesh.position) < 1.0) {
                        e.takeDamage(10);
                        p.active = false;
                        this.scene.remove(p.mesh);
                        
                        // Score logic if killed
                        if (e.health <= 0) {
                            this.score += 100;
                            this.ui.updateScore(this.score);
                            // Increase difficulty
                            this.spawnRate = Math.max(0.5, this.spawnRate - 0.05);
                        }
                        break;
                    }
                }
            }
        }
    }

    updateMousePosition(clientX, clientY) {
        if (this.state !== 'PLAYING') return;
        
        // Convert screen coordinates to normalized device coordinates (NDC)
        const mouseNDC = new THREE.Vector2(
            (clientX / window.innerWidth) * 2 - 1,
            -(clientY / window.innerHeight) * 2 + 1
        );

        this.raycaster.setFromCamera(mouseNDC, this.camera);
        const target = new THREE.Vector3();
        this.raycaster.ray.intersectPlane(this.mousePlane, target);
        
        if (target) {
            this.input.mousePos = target;
        }
    }

    handleSpawns(dt) {
        this.spawnTimer -= dt;
        if (this.spawnTimer <= 0) {
            this.spawnTimer = this.spawnRate;
            
            // Spawn at random edge
            const angle = Math.random() * Math.PI * 2;
            const radius = 18;
            const pos = new THREE.Vector3(Math.cos(angle) * radius, 0, Math.sin(angle) * radius);
            
            this.enemies.push(new Enemy(this.scene, pos, this.player));
        }
    }

    gameOver() {
        this.state = 'GAMEOVER';
        this.ui.showScreen('game-over-menu');
    }

    togglePause() {
        if (this.state === 'PLAYING') {
            this.state = 'PAUSED';
            this.ui.showScreen('pause-menu');
            this.clock.stop();
        } else if (this.state === 'PAUSED') {
            this.state = 'PLAYING';
            this.ui.showScreen('hud');
            this.clock.start();
        }
    }

    animate() {
        requestAnimationFrame(this.animate);

        const dt = this.clock.getDelta();

        if (this.state === 'PLAYING') {
            if (this.player) {
                this.player.update(dt, this.input);
                
                // Camera Follow smoothly
                const targetPos = this.player.mesh.position.clone();
                targetPos.y = 18;
                targetPos.z += 12; // offset
                this.camera.position.lerp(targetPos, 0.1);
            }

            this.handleSpawns(dt);

            this.enemies.forEach(e => e.update(dt));
            // Cleanup dead enemies
            this.enemies = this.enemies.filter(e => e.active);

            this.updateProjectiles(dt);
        }

        this.renderer.render(this.scene, this.camera);
    }

    resize() {
        this.camera.aspect = window.innerWidth / window.innerHeight;
        this.camera.updateProjectionMatrix();
        this.renderer.setSize(window.innerWidth, window.innerHeight);
    }
}
